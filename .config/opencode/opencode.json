{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "copilot",
    "permission": {
        "*": "ask",
        "task": "deny",
        "todowrite": "deny",
        "edit": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "question": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "bash": {
            "git status *": "allow",
            "git diff *": "allow",
            "git show *": "allow",
            "git log *": "allow",
            "git stash list *": "allow",
            "git stash show *": "allow",
            "grep *": "allow",
            "rg *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "find *": "allow",
            "sort *": "allow",
            "ls *": "allow",
            "wc *": "allow",
            "pwd *": "allow",
            "true *": "allow",
            "false *": "allow",
            "file *": "allow"
        }
    },
    "agent": {
        "plan": {
            "disable": true
        },
        "build": {
            "disable": true
        },
        "general": {
            "disable": true
        },
        "explore": {
            "disable": true
        },
        "scout": {
            "disable": true
        }
    }
}
