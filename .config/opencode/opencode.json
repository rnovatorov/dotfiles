{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "plan",
    "permission": {
        "*": "ask",
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "question": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "bash": {
            "go test *": "allow",
            "git push *": "deny",
            "git tag *": "deny",
            "grep *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "find *": "allow",
            "ls *": "allow",
            "cat *": "allow"
        }
    },
    "agent": {
        "plan": {
            "model": "google/gemini-3.1-pro-preview",
            "permission": {
                "edit": "deny"
            }
        },
        "build": {
            "model": "google/gemini-flash-latest",
            "permission": {}
        }
    }
}
